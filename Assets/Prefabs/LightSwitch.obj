
mtllib LightSwitch.mtl

# Plate
usemtl PlateMat
v -0.5 0 -0.3
v  0.5 0 -0.3
v  0.5 1 -0.3
v -0.5 1 -0.3
v -0.5 0  0.3
v  0.5 0  0.3
v  0.5 1  0.3
v -0.5 1  0.3

f 1 2 3 4
f 5 6 7 8
f 1 5 8 4
f 2 6 7 3
f 4 3 7 8
f 1 2 6 5

# Switch
usemtl SwitchMat
v -0.1 0.3 -0.35
v  0.1 0.3 -0.35
v  0.1 0.7 -0.35
v -0.1 0.7 -0.35
v -0.1 0.3 -0.15
v  0.1 0.3 -0.15
v  0.1 0.7 -0.15
v -0.1 0.7 -0.15

f 9 10 11 12
f 13 14 15 16
f 9 13 16 12
f 10 14 15 11
f 12 11 15 16
f 9 10 14 13
